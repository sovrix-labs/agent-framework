{
  "name": "agent-framework-cli",
  "version": "1.0.11",
  "description": "CLI tool framework for building VS Code + Copilot agents and skills with BEADS+ SpecKit workflow",
  "main": "dist/cli.js",
  "bin": {
    "agent-cli": "dist/cli.js",
    "acli": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "BEADS_WORKFLOW.md",
    "ITERATIVE_DEVELOPMENT.md",
    "MEMORY_SYSTEM.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "agents",
    "vscode",
    "copilot",
    "github-copilot",
    "ai",
    "framework",
    "beads",
    "speckit",
    "workflow",
    "tdd",
    "quality-gates",
    "agent-memory",
    "iterative-development"
  ],
  "author": "Pranjal Pandey <pranjal@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ipranjal/agent-framework.git"
  },
  "bugs": {
    "url": "https://github.com/ipranjal/agent-framework/issues"
  },
  "homepage": "https://github.com/ipranjal/agent-framework#readme",
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^4.1.2",
    "inquirer": "^8.2.5",
    "fs-extra": "^11.2.0",
    "yaml": "^2.3.4",
    "ora": "^5.4.1",
    "boxen": "^5.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/inquirer": "^8.2.10",
    "@types/fs-extra": "^11.0.4",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
